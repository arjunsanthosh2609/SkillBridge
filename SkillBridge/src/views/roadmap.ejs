<%- include("partials/head", { title: "Roadmap" }) %>

<main class="page-shell">
  <section class="topbar">
    <div>
      <p class="eyebrow">Roadmap</p>
      <h1><%= roadmap.headline %></h1>
      <p class="subtle"><%= roadmap.summary %></p>
    </div>
    <div class="status-pill">
      <span><%= isSavedRoadmap ? "View mode" : "Generated now" %></span>
      <% if (examResult) { %>
        <strong><%= examResult.level %> - <%= examResult.score %>%</strong>
      <% } else { %>
        <strong>Saved roadmap</strong>
      <% } %>
    </div>
  </section>

  <section class="page-actions">
    <a class="ghost-btn" href="/home">Back to home</a>
    <a class="ghost-btn" href="/logout">Logout</a>

  </section>

  <section class="dashboard-grid single">
    <article class="card">
      <div class="card-heading">
        <h2>Job market signals</h2>
        <p>Retrieved from the knowledge base using imported job descriptions that match your goal and skills.</p>
      </div>
      <% if (roadmap.jobSignals && roadmap.jobSignals.length) { %>
        <div class="resource-list">
          <% roadmap.jobSignals.forEach((signal) => { %>
            <a class="resource-item" href="<%= signal.sourceUrl %>" target="_blank" rel="noreferrer">
              <span class="resource-type">Job requirement</span>
              <strong><%= signal.title %></strong>
              <span class="resource-provider"><%= signal.provider %></span>
              <span class="resource-why"><%= signal.summary %></span>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <p class="resource-why">No real job-board descriptions have been imported yet. Add LinkedIn, Indeed, or Naukri JSON files in `data/job-imports/` to ground this section with live role requirements.</p>
      <% } %>
    </article>

    <% roadmap.phases.forEach((phase) => { %>
      <article class="card roadmap-phase">
        <div class="card-heading">
          <h2><%= phase.title %></h2>
          <p><%= phase.duration %></p>
        </div>
        <% if (phase.objective) { %>
          <p class="resource-why"><strong>Objective:</strong> <%= phase.objective %></p>
        <% } %>
        <ul class="phase-list">
          <% phase.actions.forEach((action) => { %>
            <li><%= action %></li>
          <% }); %>
        </ul>

        <% if (phase.resources && phase.resources.length) { %>
          <div class="resource-block">
            <h3>Study materials</h3>
            <div class="resource-list">
              <% phase.resources.forEach((resource) => { %>
                <a class="resource-item" href="<%= resource.url %>" target="_blank" rel="noreferrer">
                  <span class="resource-type"><%= resource.type %></span>
                  <strong><%= resource.title %></strong>
                  <span class="resource-provider"><%= resource.provider %></span>
                  <% if (resource.focus) { %>
                    <span class="resource-focus"><%= resource.focus %></span>
                  <% } %>
                  <% if (resource.why) { %>
                    <span class="resource-why"><%= resource.why %></span>
                  <% } %>
                </a>
              <% }); %>
            </div>
          </div>
        <% } %>
      </article>
    <% }); %>

    <% if (roadmap.datasetSuggestions && roadmap.datasetSuggestions.length) { %>
      <article class="card">
        <div class="card-heading">
          <h2>Practice datasets and repositories</h2>
          <p>Retrieved datasets and repos you can use to turn the roadmap into real projects.</p>
        </div>
        <div class="resource-list">
          <% roadmap.datasetSuggestions.forEach((dataset) => { %>
            <a class="resource-item" href="<%= dataset.sourceUrl %>" target="_blank" rel="noreferrer">
              <span class="resource-type">Dataset / repository</span>
              <strong><%= dataset.title %></strong>
              <span class="resource-provider"><%= dataset.provider %></span>
              <span class="resource-why"><%= dataset.summary %></span>
            </a>
          <% }); %>
        </div>
      </article>
    <% } %>
  </section>
</main>

<%- include("partials/foot") %>
