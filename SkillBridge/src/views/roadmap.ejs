<%- include("partials/head", { title: "Roadmap" }) %>

<main class="page-shell">
  <section class="topbar">
    <div>
      <p class="eyebrow">Roadmap</p>
      <h1><%= roadmap.headline %></h1>
      <p class="subtle">“Discipline is choosing between what you want now and what you want most.” — Abraham Lincoln</p>
    </div>
    <div class="status-pill">
      <span><%= isSavedRoadmap ? "View mode" : "Generated now" %></span>
      <% if (examResult) { %>
        <strong><%= examResult.level %> - <%= examResult.score %>%</strong>
      <% } else { %>
        <strong>Saved roadmap</strong>
      <% } %>
    </div>
  </section>

  <section class="page-actions">
    <a class="ghost-btn" href="/home">Back to home</a>

  </section>

  <section class="dashboard-grid single">
    <% if (roadmap.answers) { %>
      <article class="card">
        <div class="card-heading">
          <h2>Roadmap Summary</h2>
          <p>A direct answer to where you stand and what comes next.</p>
        </div>
        <div class="resource-list">
          <% if (roadmap.answers.whereAmINow) { %>
            <div class="resource-item">
              <strong>1. Where am I now?</strong>
              <span class="resource-why"><%= roadmap.answers.whereAmINow %></span>
            </div>
          <% } %>
          <% if (roadmap.answers.whatAmIMissing) { %>
            <div class="resource-item">
              <strong>2. What am I missing?</strong>
              <span class="resource-why"><%= roadmap.answers.whatAmIMissing %></span>
            </div>
          <% } %>
          <% if (roadmap.answers.whatShouldILearnNext) { %>
            <div class="resource-item">
              <strong>3. What should I learn next?</strong>
              <span class="resource-why"><%= roadmap.answers.whatShouldILearnNext %></span>
            </div>
          <% } %>
          <% if (roadmap.answers.whyShouldILearnIt) { %>
            <div class="resource-item">
              <strong>4. Why should I learn it?</strong>
              <span class="resource-why"><%= roadmap.answers.whyShouldILearnIt %></span>
            </div>
          <% } %>
          <% if (roadmap.answers.howShouldILearnIt) { %>
            <div class="resource-item">
              <strong>5. How should I learn it?</strong>
              <span class="resource-why"><%= roadmap.answers.howShouldILearnIt %></span>
            </div>
          <% } %>
          <% if (roadmap.answers.whenAmIJobReady) { %>
            <div class="resource-item">
              <strong>6. When am I job-ready?</strong>
              <span class="resource-why"><%= roadmap.answers.whenAmIJobReady %></span>
            </div>
          <% } %>
        </div>
      </article>
    <% } %>

    <% roadmap.phases.forEach((phase) => { %>
      <article class="card roadmap-phase">
        <div class="card-heading">
          <h2><%= phase.title %></h2>
          <p><%= phase.duration %></p>
        </div>
        <% if (phase.objective) { %>
          <p class="resource-why"><strong>Objective:</strong> <%= phase.objective %></p>
        <% } %>
        <% if (phase.actions && phase.actions.length) { %>
          <div class="resource-block">
            <h3>Focus areas</h3>
            <ul class="phase-list">
              <% phase.actions.forEach((action) => { %>
                <li><%= action %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (phase.steps && phase.steps.length) { %>
          <div class="resource-block">
            <h3>Step-by-step plan</h3>
            <ul class="phase-list">
              <% phase.steps.forEach((step) => { %>
                <li><%= step %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (phase.deliverables && phase.deliverables.length) { %>
          <div class="resource-block">
            <h3>Expected deliverables</h3>
            <ul class="phase-list">
              <% phase.deliverables.forEach((deliverable) => { %>
                <li><%= deliverable %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (phase.practiceAssignments && phase.practiceAssignments.length) { %>
          <div class="resource-block">
            <h3>Practice assignments</h3>
            <ul class="phase-list">
              <% phase.practiceAssignments.forEach((assignment) => { %>
                <li><%= assignment %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (phase.projectRecommendations && phase.projectRecommendations.length) { %>
          <div class="resource-block">
            <h3>Project recommendations</h3>
            <ul class="phase-list">
              <% phase.projectRecommendations.forEach((project) => { %>
                <li><%= project %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

      </article>
    <% }); %>

    <% if (roadmap.datasetSuggestions && roadmap.datasetSuggestions.length) { %>
      <article class="card">
        <div class="card-heading">
          <h2>Practice datasets and repositories</h2>
          <p>Retrieved datasets and repos you can use to turn the roadmap into real projects.</p>
        </div>
        <div class="resource-list">
          <% roadmap.datasetSuggestions.forEach((dataset) => { %>
            <a class="resource-item" href="<%= dataset.sourceUrl %>" target="_blank" rel="noreferrer">
              <span class="resource-type">Dataset / repository</span>
              <strong><%= dataset.title %></strong>
              <span class="resource-provider"><%= dataset.provider %></span>
              <span class="resource-why"><%= dataset.summary %></span>
            </a>
          <% }); %>
        </div>
      </article>
    <% } %>
  </section>
</main>

<%- include("partials/foot") %>
