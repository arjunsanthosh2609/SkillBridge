<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SkillBridge Mobile Scanner</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center vh-100">
    <div class="container text-center">
        <h3>Resume Scanner</h3>
        <p>Take a clear photo of your skills section</p>
        
        <input type="file" id="cameraInput" accept="image/*" capture="camera" class="d-none">
        <button class="btn btn-primary btn-lg w-100 mb-3" onclick="document.getElementById('cameraInput').click()">
            Take Photo / Upload
        </button>

        <div id="status" class="mt-3"></div>
    </div>

    <script>
        const sessionId = "<%= sessionId %>";
        document.getElementById('cameraInput').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            document.getElementById('status').innerText = "Processing... please wait.";
            
            // Convert image to Base64
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = async () => {
                const response = await fetch('/extract-skills', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ image: reader.result, sessionId: sessionId })
                });
                
                if (response.ok) {
                    document.getElementById('status').innerHTML = "<b class='text-success'>Done! You can close this tab and check your computer.</b>";
                } else {
                    document.getElementById('status').innerText = "Error uploading. Try again.";
                }
            };
        });
    </script>
</body>
</html>