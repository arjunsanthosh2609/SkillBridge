<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    :root {
      color-scheme: light;
      color: #111;
      background: #fff;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      margin: 0;
      padding: 0;
      background: #f5f5f5;
    }

    .resume-shell {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding: 32px;
      background: #ffffff;
      box-shadow: 0 0 0 rgba(0, 0, 0, 0);
    }

    .resume-header {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-bottom: 18px;
      border-bottom: 2px solid #111;
      margin-bottom: 28px;
    }

    .resume-header h1 {
      font-size: 28px;
      letter-spacing: -0.04em;
      margin: 0;
    }

    .resume-header p {
      margin: 0;
      font-size: 12px;
      color: #555;
      white-space: pre-wrap;
      line-height: 1.5;
    }

    .section {
      margin-bottom: 22px;
      page-break-inside: avoid;
    }

    .section-title {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
      color: #111;
      margin-bottom: 12px;
    }

    .section-title::before {
      content: "";
      width: 36px;
      height: 1px;
      background: #111;
    }

    .section-item {
      font-size: 10.7px;
      line-height: 1.55;
      color: #222;
      margin-bottom: 8px;
    }

    .section-item strong {
      font-weight: 600;
    }

    .bullet {
      display: inline-flex;
      gap: 8px;
      align-items: flex-start;
    }

    .bullet span:first-child {
      line-height: 1.4;
    }

    .bullet-text {
      flex: 1;
    }

    .resume-footer {
      padding-top: 16px;
      border-top: 1px solid #e2e2e2;
      font-size: 10px;
      color: #666;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <div class="resume-shell">
    <div class="resume-header">
      <h1><%= headerName %></h1>
      <p><%= headerContact %></p>
    </div>

    <% orderedSectionNames.forEach((sectionName) => { %>
      <% const items = sections[sectionName] || []; %>
      <% if (items.length > 0) { %>
        <section class="section">
          <div class="section-title"><%= sectionName %></div>
          <% items.forEach((item) => { %>
            <% const match = item.match(/^([•*\-]|\d+\.)\s*(.*)$/); %>
            <% if (match) { %>
              <div class="section-item">
                <div class="bullet">
                  <span>•</span>
                  <span class="bullet-text"><%= match[2] %></span>
                </div>
              </div>
            <% } else { %>
              <div class="section-item">
                <%= item.replace(/\n/g, '<br>') %>
              </div>
            <% } %>
          <% }); %>
        </section>
      <% } %>
    <% }); %>

    <div class="resume-footer">Generated by SkillBridge · Clean resume layout for ATS-friendly PDF export</div>
  </div>
</body>
</html>
