<%- include("partials/head", { title: "Sign Up" }) %>

<main class="auth-shell">
  <section class="hero-panel">
    <p class="eyebrow">SkillBridge</p>
    <h1>AI resume screener and skill gap analyser</h1>
    <p class="hero-copy">
      Upload your resume, extract your current skills, measure your level with a goal-based exam,
      and unlock a personalized roadmap.
    </p>
    <div class="hero-points">
      <span>Resume NLP extraction</span>
      <span>Goal-aware skill assessment</span>
      <span>Dynamic trend insights</span>
    </div>
  </section>

  <section class="form-panel">
    <div class="panel-header">
      <h2>Create your account</h2>
      <p>Fill in the required details and upload your latest resume.</p>
    </div>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form class="app-form" id="signupForm" action="/signup" method="POST" enctype="multipart/form-data">
      <div class="grid two">
        <label>
          Full name
          <input type="text" name="fullName" value="<%= formData.fullName || '' %>" required />
        </label>
        <label>
          Email
          <input type="email" name="email" value="<%= formData.email || '' %>" required />
        </label>
      </div>

      <div class="grid two">
        <label>
          Phone number
          <input type="tel" name="phone" value="<%= formData.phone || '' %>" required />
        </label>
        <label>
          Password
          <input type="password" name="password" required />
        </label>
      </div>

      <div class="grid two">
        <label>
          Confirm password
          <input type="password" name="confirmPassword" required />
        </label>
        <div class="empty-slot" aria-hidden="true"></div>
      </div>

      <div class="grid two">
        <label>
          Education
          <input type="text" name="education" value="<%= formData.education || '' %>" placeholder="B.Tech CSE" required />
        </label>
        <label>
          Location
          <input type="text" name="location" value="<%= formData.location || '' %>" required />
        </label>
      </div>

      <div class="grid two">
        <label>
          Experience (years)
          <input type="number" min="0" max="30" name="experienceYears" value="<%= formData.experienceYears || '' %>" required />
        </label>
        <label>
          Career goal
          <select name="goal" required>
            <option value="">Select your goal</option>
            <% goals.forEach((goal) => { %>
              <option value="<%= goal %>" <%= formData.goal === goal ? 'selected' : '' %>><%= goal %></option>
            <% }); %>
          </select>
        </label>
      </div>

            <div class="field-group">
                <label>Resume document</label>
                <p class="helper-text">Upload your resume or use the mobile scan option to extract skills quickly.</p>
                <input type="file" id="resumeFile" name="resume" class="form-control" />
                <input type="hidden" id="mobileScannedSkills" name="mobileScannedSkills" value="<%= formData.mobileScannedSkills || '' %>" />
                
                <div id="scan-status" class="mt-2" style="font-size: 0.85rem; font-weight: bold;"></div>
                
                <div class="mt-2 text-start">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="openMobileScanner()">
                        <i class="bi bi-phone"></i> Upload from Mobile
                    </button>
                </div>
            </div>

            <button class="primary-btn" type="submit">Create account and analyse resume</button>
            <p class="auth-footer">Already have an account? <a href="/login">Login here</a></p>
        </form>
    </section>
</main>

<div class="modal fade" id="mobileScannerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div class="modal-body text-center style=padding-left:270px:">
                <h6 class="mb-3">Scan with Mobile</h6>
                <div id="qrcode" class="d-flex justify-content-center mb-3"></div>
                <div id="scanStatusBadge" class="badge bg-secondary">Waiting for scan...</div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
let scanInterval;

function openMobileScanner() {
    const sessionId = 'SB-' + Math.random().toString(36).substr(2, 9);
    // Ensure this matches your ipconfig IP (10.112.80.103)
    const mobileUrl = 'http://10.112.80.138:3000/mobile-upload-page?id=' + sessionId;
    
    document.getElementById("qrcode").innerHTML = "";
    new QRCode(document.getElementById("qrcode"), { 
        text: mobileUrl, 
        width: 160, 
        height: 160,
        colorDark : "#000000",
        colorLight : "#ffffff",
        correctLevel : QRCode.CorrectLevel.H
    });

    const modalElement = document.getElementById('mobileScannerModal');
    const myModal = bootstrap.Modal.getOrCreateInstance(modalElement);
    myModal.show();

    // Check for data every 2 seconds
    scanInterval = setInterval(async () => {
        try {
            const res = await fetch('/check-scan/' + sessionId);
            const data = await res.json();

            if (data.status === 'completed') {
                document.getElementById('mobileScannedSkills').value = data.skills;
                document.getElementById('scan-status').innerHTML = `<span style="color: #28a745;">✅ Skills Synchronized: ${data.skills}</span>`;
                
                const badge = document.getElementById('scanStatusBadge');
                badge.className = "badge bg-success";
                badge.innerText = "Connected!";
                
                clearInterval(scanInterval);
                setTimeout(() => myModal.hide(), 1500);
            }
        } catch (err) { console.error("Sync error:", err); }
    }, 2000); 
}

// Client-side validation: must have file OR mobile scan
document.getElementById('signupForm').addEventListener('submit', function(e) {
    const hasFile = document.getElementById('resumeFile').files.length > 0;
    const hasMobile = document.getElementById('mobileScannedSkills').value.length > 0;

    if (!hasFile && !hasMobile) {
        e.preventDefault();
        alert("Please upload a resume file OR use the mobile scanner to continue.");
    }
});
</script>
